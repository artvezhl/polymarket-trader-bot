# Polymarket CLOB API credentials
PRIVATE_KEY=your_ethereum_private_key_here
POLYMARKET_API_KEY=your_api_key
POLYMARKET_API_SECRET=your_api_secret
POLYMARKET_API_PASSPHRASE=your_api_passphrase

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Polygon RPC (optional). Старый https://polygon-rpc.com часто даёт 401 из Docker — лучше PublicNode или Alchemy/Infura.
POLYGON_RPC_URL=https://polygon-bor.publicnode.com

# Proxy (Gnosis Safe) — для CLOB с funder и для on-chain redeem через Safe (SIG_TYPE 1/2)
POLYMARKET_PROXY_ADDRESS=

# Тип подписи CLOB: 0=EOA (redeem только если CTF-токены на EOA из PRIVATE_KEY), 1=POLY_PROXY, 2=GNOSIS_SAFE (токены на Safe — нужен POLYMARKET_PROXY_ADDRESS)
# POLYMARKET_SIG_TYPE=2

# Relayer (gasless redeem): https://docs.polymarket.com/trading/gasless — не нужен MATIC на EOA
# Создать ключи: Polymarket → Settings → API Keys
# RELAYER_API_KEY=
# RELAYER_API_KEY_ADDRESS=
